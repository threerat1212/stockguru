# AI Provider (MiMo)
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MAX_TOKENS=700
MIMO_TIMEOUT_MS=20000

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=700
DEEPSEEK_TIMEOUT_MS=20000

# OpenRouter War Room Debate
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_second_openrouter_api_key_here
# OPENROUTER_API_KEYS=your_first_openrouter_api_key_here,your_second_openrouter_api_key_here
AGENT_LOOP_LLM_PROVIDER=openrouter
AGENT_LOOP_LLM_BASE_URL=https://openrouter.ai/api/v1
AGENT_LOOP_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
AGENT_LOOP_LLM_MAX_TOKENS=700
AGENT_LOOP_LLM_TIMEOUT_MS=20000
AGENT_LOOP_LLM_DEBATE_ASSIST=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs (optional — if set, used directly; if not, fallback to price_data)
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_FOUNDING_PRO=price_xxx
# STRIPE_PRICE_TRADER=price_xxx

# Cron job secret (for /api/news/refresh protection)
# CRON_SECRET=your_random_secret_for_cron_jobs

# Email alerts (Resend) — required for price alert emails in production
# RESEND_API_KEY=re_xxxxxxxx

# Optional: Custom yahoo-finance2 config
# YAHOO_FINANCE_PROXY=http://your-proxy:8080
