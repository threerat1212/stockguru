# AI Provider (MiMo)
MIMO_API_KEY=your_mimo_api_key_here
# Base URL for the MiMo API. Default works for pay-as-you-go (sk-) keys.
# Token Plan (tp-) keys need a cluster URL, e.g.:
#   https://token-plan-sgp.xiaomimimo.com/v1  (Singapore)
#   https://token-plan-cn.xiaomimimo.com/v1   (China)
#   https://token-plan-ams.xiaomimimo.com/v1  (Europe)
# MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (for subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Stripe Price IDs (optional — if set, used directly; if not, fallback to price_data)
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_FOUNDING_PRO=price_xxx
# STRIPE_PRICE_TRADER=price_xxx

# Cron job secret (for /api/news/refresh protection)
# CRON_SECRET=your_random_secret_for_cron_jobs

# Email alerts (Resend) — required for price alert emails in production
# RESEND_API_KEY=re_xxxxxxxx

# Optional: Custom yahoo-finance2 config
# YAHOO_FINANCE_PROXY=http://your-proxy:8080
